{
  "id": "platform-profile-android",
  "name": "Android Platform Profile",
  "platform": "Android",
  "isBuiltIn": true,
  "checks": {
    "shaderFeatures": {
      "unsupported": [
        "Tessellation",
        "GeometryShader",
        "HighPrecisionFloat"
      ],
      "alternatives": {
        "Tessellation": "LOD Mesh",
        "GeometryShader": "Particle System / Vertex Shader",
        "HighPrecisionFloat": "mediump (half precision)"
      }
    },
    "memoryBudget": {
      "maxTextureMB": 120,
      "maxMeshMB": 60,
      "maxAudioMB": 30,
      "maxTotalMB": 300
    },
    "scriptingConstraints": {
      "disallowedAPIs": [
        "System.Reflection.Emit",
        "System.Runtime.Remoting"
      ],
      "requiredDefines": [
        "UNITY_ANDROID"
      ]
    },
    "graphicsApi": {
      "recommended": "Vulkan",
      "fallback": "OpenGLES3",
      "notes": "Unity 6 recommends Vulkan as the primary Graphics API on Android. OpenGL ES 3 remains a compatibility fallback for older/unsupported devices, but the URP GPU Resident Drawer (draw-call reduction via BatchRendererGroup GPU instancing) and other compute-shader-based render features are unavailable on OpenGL ES."
    }
  }
}
