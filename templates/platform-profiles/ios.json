{
  "id": "platform-profile-ios",
  "name": "iOS Platform Profile",
  "platform": "iOS",
  "isBuiltIn": true,
  "checks": {
    "shaderFeatures": {
      "unsupported": [
        "Tessellation",
        "GeometryShader",
        "ComputeShader_Legacy"
      ],
      "alternatives": {
        "Tessellation": "Vertex Displacement Map",
        "GeometryShader": "Vertex Shader + GPU Instancing",
        "ComputeShader_Legacy": "Metal Compute (A8+ GPU)"
      }
    },
    "memoryBudget": {
      "maxTextureMB": 150,
      "maxMeshMB": 80,
      "maxAudioMB": 40,
      "maxTotalMB": 400
    },
    "scriptingConstraints": {
      "disallowedAPIs": [
        "System.Reflection.Emit",
        "System.Runtime.Remoting"
      ],
      "requiredDefines": [
        "UNITY_IOS"
      ]
    },
    "graphicsApi": {
      "recommended": "Metal",
      "fallback": "n/a",
      "notes": "Metal supports compute shaders, so the URP GPU Resident Drawer and Forward+/Deferred+ rendering paths (Unity 6+) are supported on iOS. VisionOS (Apple's spatial computing platform) is a separate profile — GPU Resident Drawer is explicitly unsupported there even though it shares the Metal API."
    }
  }
}
