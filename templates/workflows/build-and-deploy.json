{
  "id": "wf-build-and-deploy",
  "name": "Build & Deploy",
  "description": "Loads a build configuration, executes the Unity build, monitors progress, and verifies the output artifact.",
  "isBuiltIn": true,
  "steps": [
    {
      "id": "load-config",
      "name": "Load build configuration (read current Player Settings before building)",
      "mcpTool": "manage_build",
      "mcpAction": "settings",
      "mcpArgs": { "property": "scripting_backend" },
      "dependsOn": [],
      "onFailure": "abort"
    },
    {
      "id": "execute-build",
      "name": "Execute Unity build",
      "mcpTool": "manage_build",
      "mcpAction": "build",
      "mcpArgs": { "target": "windows64", "scenes": "[]", "output_path": "Builds/Windows/MyGame.exe" },
      "dependsOn": ["load-config"],
      "onFailure": "pause"
    },
    {
      "id": "monitor-progress",
      "name": "Monitor build progress via job status and console",
      "mcpTool": "manage_build",
      "mcpAction": "status",
      "mcpArgs": {},
      "dependsOn": ["execute-build"],
      "onFailure": "skip"
    },
    {
      "id": "verify-artifact",
      "name": "Verify build artifact exists",
      "mcpTool": "manage_asset",
      "mcpAction": "get_info",
      "mcpArgs": { "path": "Builds/Windows/MyGame.exe" },
      "dependsOn": ["monitor-progress"],
      "onFailure": "pause"
    }
  ],
  "createdAt": "2026-01-01T00:00:00Z"
}
