{
  "enabled": true,
  "name": "Setup Unity Auto Power",
  "description": "一鍵將 Unity Power 的 steering 範本複製到 Kiro 使用者設定目錄，啟用自動最佳實踐",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "mkdir -p ~/.kiro/steering && cp kiro-unity-power/steering-template/unity-auto-power.md ~/.kiro/steering/unity-auto-power.md && echo \"✅ Unity Auto Power steering 已安裝到 ~/.kiro/steering/\""
  }
}